# ============ Main ============

COMMAND="${1:-}"
shift 2>/dev/null || true

case "$COMMAND" in
    config)
        subcmd="${1:-}"
        shift
        case "$subcmd" in
            show)
                cmd_config_show
                ;;
            set)
                cmd_config_set "$@"
                ;;
            voice)
                if [[ "${1:-}" == "list" ]]; then
                    cmd_config_voice_list
                fi
                ;;
            model)
                if [[ "${1:-}" == "list" ]]; then
                    cmd_config_model_list
                fi
                ;;
            *)
                echo -e "${RED}Usage: minimax config [show|set|voice list|model list]${NC}"
                exit 1
                ;;
        esac
        ;;
    chat)
        cmd_chat "$@"
        ;;
    tts)
        cmd_tts "$@"
        ;;
    image)
        cmd_image "$@"
        ;;
    vision)
        cmd_vision "$@"
        ;;
    music)
        cmd_music "$@"
        ;;
    search)
        cmd_search "$@"
        ;;
    models)
        cmd_models
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        if [[ -z "$COMMAND" ]]; then
            usage
        else
            echo -e "${RED}Unknown command: $COMMAND${NC}"
            usage
        fi
        ;;
esac
