#!/bin/bash
# MiniMax CLI - Enhanced OpenAI-compatible API client
# Version: 1.0.0

set -e

VERSION="1.0.0"
CONFIG_FILE="${HOME}/.minimax-cli.conf"

# Default values
DEFAULT_API_URL="https://mimimax.cn"
DEFAULT_CHAT_MODEL="MiniMax-M2.7-highspeed"
DEFAULT_TTS_MODEL="speech-2.8-turbo"
DEFAULT_TTS_VOICE="Chinese (Mandarin)_Gentleman"
DEFAULT_TTS_SPEED="1.0"
DEFAULT_TTS_PITCH="1.0"
DEFAULT_IMAGE_MODEL="image-01"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    cat << EOF
${CYAN}MiniMax CLI v${VERSION}${NC} - OpenAI-compatible API client

${GREEN}Usage:${NC} minimax <command> [options]

${GREEN}Commands:${NC}
  ${YELLOW}chat${NC} <message>              AI 对话
  ${YELLOW}tts${NC} <text> [-o file]       文字转语音
  ${YELLOW}image${NC} <prompt> [-o file]    图片生成
  ${YELLOW}vision${NC} <image> <prompt>     图片理解
  ${YELLOW}music${NC} <prompt> [-o file]    音乐生成
  ${YELLOW}search${NC} <query>              网络搜索
  ${YELLOW}config${NC} [show|set|voice|model]  配置管理
  ${YELLOW}models${NC}                      列出可用模型

${GREEN}TTS Options:${NC}
  -o, --output <file>        输出文件 (默认: tts_内容前10字.mp3)
  -v, --voice <voice>        声音角色
  --speed <0.5-2.0>          语速
  --pitch <0.5-2.0>          音调
  --no-stream                 同步模式 (默认: 流式，无缓存问题)

${GREEN}文本格式 (语气词和停顿):${NC}
  语气词: (laughs)(chuckle)(coughs)(sighs)(breath) 等
  停顿: <#秒数#> 如 <#1.5#> 表示 1.5 秒停顿
  示例: “你好(chuckles)<#1.0#>我们去散步吧”

${GREEN}Image Options:${NC}
  -o, --output <file>        输出文件 (默认: image.png)
  -m, --model <model>        模型 (image-01/image-01-live)
  --style <type>             画风 (漫画/元气/中世纪/水彩)
  --style-weight <0-1>       画风权重 (默认: 0.8)
  --ratio <ratio>            比例 (1:1/16:9/4:3/3:2/9:16)
  -n, --count <1-9>         生成数量
  --seed <num>              随机种子
  --optimize                 启用 prompt 优化
  --base64                   返回 base64 格式
  --watermark                 添加水印

${GREEN}Examples:${NC}
  minimax image “一只猫”
  minimax image “风景画” --style 漫画 --ratio 16:9 -o landscape.png
  minimax image “插画” --style 水彩 -n 4
  minimax image “写真” --base64 -o photo.jpg
  minimax config set api.key <your-key>
  minimax config voice list
  minimax tts “你好世界”
  minimax tts “你好(laughs)<#1.0#>我们去散步” -v “Chinese (Mandarin)_Gentleman”
  minimax music “独立民谣” -s “忧郁,内省”
  minimax music “城市夜景” -l “[verse]\n街灯微亮\n旧外套裹着忧郁” -o song.mp3

EOF
    exit 1
}

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
    # Set defaults if not configured
    API_URL="${API_URL:-${DEFAULT_API_URL}}"
    CHAT_MODEL="${CHAT_MODEL:-${DEFAULT_CHAT_MODEL}}"
    TTS_MODEL="${TTS_MODEL:-${DEFAULT_TTS_MODEL}}"
    TTS_VOICE="${TTS_VOICE:-${DEFAULT_TTS_VOICE}}"
    TTS_SPEED="${TTS_SPEED:-${DEFAULT_TTS_SPEED}}"
    TTS_PITCH="${TTS_PITCH:-${DEFAULT_TTS_PITCH}}"
    IMAGE_MODEL="${IMAGE_MODEL:-${DEFAULT_IMAGE_MODEL}}"
}

save_config() {
    cat > "$CONFIG_FILE" << EOF
API_URL="${API_URL}"
API_KEY="${API_KEY}"
CHAT_MODEL="${CHAT_MODEL}"
TTS_MODEL="${TTS_MODEL}"
TTS_VOICE="${TTS_VOICE}"
TTS_SPEED="${TTS_SPEED}"
TTS_PITCH="${TTS_PITCH}"
IMAGE_MODEL="${IMAGE_MODEL}"
EOF
    chmod 600 "$CONFIG_FILE"
}

check_config() {
    if [[ -z "$API_KEY" ]]; then
        echo -e "${RED}Error: Not configured. Run:${NC}"
        echo "  minimax config set api.key <your-key>"
        exit 1
    fi
}

# ============ Config Commands ============

cmd_config_show() {
    load_config
    echo -e "${CYAN}Current Configuration:${NC}"
    echo ""
    echo -e "${YELLOW}API:${NC}"
    echo "  URL:    ${API_URL}"
    echo "  Key:    ${API_KEY:0:8}..."
    echo ""
    echo -e "${YELLOW}Chat:${NC}"
    echo "  Model:  ${CHAT_MODEL}"
    echo ""
    echo -e "${YELLOW}TTS:${NC}"
    echo "  Model:  ${TTS_MODEL}"
    echo "  Voice:  ${TTS_VOICE}"
    echo "  Speed:  ${TTS_SPEED}"
    echo "  Pitch:  ${TTS_PITCH}"
    echo ""
    echo -e "${YELLOW}Image:${NC}"
    echo "  Model:  ${IMAGE_MODEL}"
}

cmd_config_set() {
    local key="$1"
    local value="$2"

    if [[ -z "$key" ]] || [[ -z "$value" ]]; then
        echo -e "${RED}Usage: minimax config set <key> <value>${NC}"
        echo ""
        echo -e "${YELLOW}Available keys:${NC}"
        echo "  api.url, api.key"
        echo "  chat.model"
        echo "  tts.model, tts.voice, tts.speed, tts.pitch"
        echo "  image.model"
        exit 1
    fi

    load_config

    case "$key" in
        api.url)
            API_URL="$value"
            ;;
        api.key)
            API_KEY="$value"
            ;;
        chat.model)
            CHAT_MODEL="$value"
            ;;
        tts.model)
            TTS_MODEL="$value"
            ;;
        tts.voice)
            TTS_VOICE="$value"
            ;;
        tts.speed)
            TTS_SPEED="$value"
            ;;
        tts.pitch)
            TTS_PITCH="$value"
            ;;
        image.model)
            IMAGE_MODEL="$value"
            ;;
        *)
            echo -e "${RED}Unknown config key: $key${NC}"
            exit 1
            ;;
    esac

    save_config
    echo -e "${GREEN}Set $key = $value${NC}"
}

cmd_config_voice_list() {
    echo -e "${CYAN}Available TTS Voices:${NC}"
    echo ""
    echo -e "${GREEN}推荐音色 (Chinese):${NC}"

    # Try to read from voices.json file first
    local voice_file=""
    for dir in "${HOME}/.claude/skills/minimax" "/usr/local/share/minimax" "."; do
        if [[ -f "$dir/voices.json" ]]; then
            voice_file="$dir/voices.json"
            break
        fi
    done

    if [[ -n "$voice_file" ]] && command -v python3 &>/dev/null; then
        python3 << PYEOF
import json, sys
try:
    with open('$voice_file', 'r', encoding='utf-8') as f:
        d = json.load(f)
    voices = d.get('system_voice', [])
    # Group by language
    cn_voices = []
    en_voices = []
    other_voices = []
    for v in voices:
        vid = v.get('voice_id', '')
        name = v.get('voice_name', '')
        if any(x in vid for x in ['female', 'male', 'Chinese', 'Cantonese']):
            cn_voices.append((vid, name))
        elif any(x in vid for x in ['English']):
            en_voices.append((vid, name))
        else:
            other_voices.append((vid, name))

    print("  ${YELLOW}=== 中文音色 ===${NC}")
    for vid, name in sorted(cn_voices, key=lambda x: x[0])[:20]:
        print(f"  {vid:40s} - {name}")
    if len(cn_voices) > 20:
        print(f"  ... (共 {len(cn_voices)} 个中文音色)")

    print()
    print("  ${YELLOW}=== English Voices ===${NC}")
    for vid, name in sorted(en_voices, key=lambda x: x[0])[:10]:
        print(f"  {vid:40s} - {name}")
    if len(en_voices) > 10:
        print(f"  ... (共 {len(en_voices)} 个英文音色)")

    print()
    print("  ${YELLOW}=== Other Languages ===${NC}")
    for vid, name in sorted(other_voices, key=lambda x: x[0])[:15]:
        print(f"  {vid:40s} - {name}")
    if len(other_voices) > 15:
        print(f"  ... (共 {len(other_voices)} 个其他音色)")

    print()
    print(f"  ${GREEN}总计: {len(voices)} 个音色${NC}")
    print()
    print(f"  完整列表请查看: $voice_file")
except Exception as e:
    print(f"Error loading voices: {e}")
PYEOF
    else
        echo "  female-tianmei              - 甜美女性音色"
        echo "  female-yujie                - 御姐音色"
        echo "  female-chengshu             - 成熟女性音色"
        echo "  female-shaonv               - 少女音色"
        echo "  male-qn-qingse              - 青涩青年音色"
        echo "  male-qn-badao               - 霸道青年音色"
        echo "  ..."
        echo ""
        echo "  完整列表请查看: voices.json"
    fi

    echo ""
    echo -e "Current default: ${GREEN}${TTS_VOICE}${NC}"
    echo ""
    echo -e "To test a voice: ${YELLOW}minimax tts \"测试\" -v <voice-id>${NC}"
}

